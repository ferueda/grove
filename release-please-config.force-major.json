{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "changelog-sections": [
    {
      "type": "feat",
      "section": "Features"
    },
    {
      "type": "fix",
      "section": "Bug Fixes"
    },
    {
      "type": "perf",
      "section": "Performance Improvements"
    },
    {
      "type": "revert",
      "section": "Reverts"
    },
    {
      "type": "deps",
      "section": "Dependencies"
    },
    {
      "type": "deps-dev",
      "section": "Development Dependencies"
    },
    {
      "type": "chore",
      "section": "Dependencies"
    },
    {
      "type": "build",
      "section": "Dependencies"
    },
    {
      "type": "docs",
      "section": "Documentation",
      "hidden": true
    },
    {
      "type": "style",
      "section": "Styles",
      "hidden": true
    },
    {
      "type": "refactor",
      "section": "Code Refactoring",
      "hidden": true
    },
    {
      "type": "test",
      "section": "Tests",
      "hidden": true
    },
    {
      "type": "ci",
      "section": "Continuous Integration",
      "hidden": true
    }
  ],
  "packages": {
    "packages/grove": {
      "release-type": "node",
      "versioning": "always-bump-major"
    },
    "packages/grove-cli": {
      "release-type": "node",
      "versioning": "always-bump-major"
    }
  }
}
